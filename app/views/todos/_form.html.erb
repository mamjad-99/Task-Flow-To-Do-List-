<%= form_with(model: todo) do |form| %>
  <% if todo.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(todo.errors.count, "error") %> prohibited this todo from being saved:</h2>

      <ul>
        <% todo.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>


  <div class="form-group field">
    <%= form.text_field :title, class:"form-control", placeholder:"Title" %>
  </div>

  <div class="form-group field">
    <%= form.text_area :task, class:"form-control", placeholder:"Description`" %>
  </div>

  <div class="form-group field">
    <%= form.date_field :date, class:"form-control", placeholder:"Date" %>
  </div>

  <div class="form-group field">
    <%= form.time_field :time, class:"form-control", placeholder:"Time" %>
  </div>

  <div class="form-group field">
    <%= form.hidden_field :status, value: false %>
  </div>

  <div class="form-group field">
    <%= form.number_field :user_id, id: :todos_user_id, class:"form-control", value:current_user.id, type: :hidden %>
  </div>

  
  <br/>
  
  <div class="actions">
    <%= form.submit(todo.new_record? ? "Create" : "Update", class: "btn btn-secondary") %>
  </div>
<% end %>
